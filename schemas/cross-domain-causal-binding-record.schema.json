{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/SamuraiWriter7/economic-trace-translation-protocol/main/schemas/cross-domain-causal-binding-record.schema.json",
  "title": "Cross-Domain Causal Binding Record",
  "description": "A machine-readable record for binding normalized economic events and structural role classifications into cross-domain causal graphs without asserting economic contribution, allocation eligibility, or royalty entitlement.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "binding_id",
    "created_at",
    "binding_profile",
    "source_records",
    "causal_nodes",
    "causal_edges",
    "causal_paths",
    "continuity_assessments",
    "review",
    "binding_status"
  ],
  "properties": {
    "schema_version": {
      "const": "0.3.0"
    },
    "record_type": {
      "const": "cross_domain_causal_binding_record"
    },
    "binding_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "binding_profile": {
      "$ref": "#/$defs/binding_profile"
    },
    "source_records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source_record"
      },
      "minItems": 2,
      "maxItems": 500
    },
    "causal_nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/causal_node"
      },
      "minItems": 2,
      "maxItems": 1000
    },
    "causal_edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/causal_edge"
      },
      "minItems": 1,
      "maxItems": 2000
    },
    "causal_paths": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/causal_path"
      },
      "minItems": 1,
      "maxItems": 500
    },
    "continuity_assessments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/continuity_assessment"
      },
      "minItems": 1,
      "maxItems": 1000
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/unresolved_item"
      },
      "maxItems": 500
    },
    "review": {
      "$ref": "#/$defs/review"
    },
    "binding_status": {
      "type": "string",
      "enum": [
        "draft",
        "review_required",
        "accepted",
        "rejected",
        "disputed",
        "superseded"
      ]
    },
    "notes": {
      "type": "string",
      "maxLength": 5000
    },
    "supersedes_ref": {
      "$ref": "#/$defs/reference"
    },
    "superseded_by_ref": {
      "$ref": "#/$defs/reference"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "binding_status": {
            "const": "accepted"
          }
        },
        "required": [
          "binding_status"
        ]
      },
      "then": {
        "properties": {
          "review": {
            "properties": {
              "review_status": {
                "enum": [
                  "not_required",
                  "approved"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "binding_status": {
            "const": "superseded"
          }
        },
        "required": [
          "binding_status"
        ]
      },
      "then": {
        "required": [
          "superseded_by_ref"
        ]
      }
    }
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref_id",
        "ref_type"
      ],
      "properties": {
        "ref_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "ref_type": {
          "type": "string",
          "enum": [
            "translation_record",
            "classification_record",
            "causal_binding_record",
            "event",
            "actor",
            "dataset",
            "system",
            "decision",
            "outcome",
            "policy",
            "rule",
            "evidence",
            "audit",
            "external_record",
            "other"
          ]
        },
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "digest": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "description": {
          "type": "string",
          "maxLength": 1200
        }
      }
    },
    "reference_list": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      },
      "uniqueItems": true,
      "maxItems": 200
    },
    "source_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_ref",
        "record_type",
        "schema_version",
        "record_status"
      ],
      "properties": {
        "record_ref": {
          "$ref": "#/$defs/reference"
        },
        "record_type": {
          "type": "string",
          "enum": [
            "economic_event_translation_record",
            "structural_role_classification_record",
            "external_record"
          ]
        },
        "schema_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "record_status": {
          "type": "string",
          "enum": [
            "draft",
            "normalized",
            "review_required",
            "accepted",
            "rejected",
            "disputed",
            "external"
          ]
        },
        "included_subject_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true,
          "maxItems": 200
        }
      }
    },
    "binder": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binder_ref",
        "binder_type"
      ],
      "properties": {
        "binder_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "binder_type": {
          "type": "string",
          "enum": [
            "human",
            "organization",
            "ai_agent",
            "automated_system",
            "hybrid",
            "other"
          ]
        },
        "system_name": {
          "type": "string",
          "maxLength": 256
        },
        "system_version": {
          "type": "string",
          "maxLength": 128
        }
      }
    },
    "binding_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "profile_version",
        "binding_method",
        "binder",
        "confidence_scale"
      ],
      "properties": {
        "profile_id": {
          "const": "ettp-cross-domain-causal-binding"
        },
        "profile_version": {
          "const": "0.3.0"
        },
        "binding_method": {
          "type": "string",
          "enum": [
            "rule_based",
            "model_assisted",
            "human_assigned",
            "hybrid"
          ]
        },
        "binder": {
          "$ref": "#/$defs/binder"
        },
        "confidence_scale": {
          "const": "0_to_1"
        },
        "policy_refs": {
          "$ref": "#/$defs/reference_list"
        },
        "model_refs": {
          "$ref": "#/$defs/reference_list"
        }
      }
    },
    "temporal_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "time_status"
      ],
      "properties": {
        "time_status": {
          "type": "string",
          "enum": [
            "exact",
            "estimated",
            "interval",
            "unknown"
          ]
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "start_at": {
          "type": "string",
          "format": "date-time"
        },
        "end_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_timezone": {
          "type": "string",
          "maxLength": 128
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "time_status": {
                "enum": [
                  "exact",
                  "estimated"
                ]
              }
            },
            "required": [
              "time_status"
            ]
          },
          "then": {
            "required": [
              "occurred_at"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "time_status": {
                "const": "interval"
              }
            },
            "required": [
              "time_status"
            ]
          },
          "then": {
            "required": [
              "start_at",
              "end_at"
            ]
          }
        }
      ]
    },
    "causal_node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "node_type",
        "domain",
        "observation_status",
        "temporal_context",
        "source_record_refs",
        "summary"
      ],
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 4,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "node_type": {
          "type": "string",
          "enum": [
            "event",
            "actor_action",
            "system_action",
            "dataset_state",
            "decision",
            "transfer",
            "verification",
            "constraint",
            "outcome",
            "other"
          ]
        },
        "domain": {
          "type": "string",
          "enum": [
            "telecom",
            "finance",
            "ai",
            "platform",
            "human",
            "organization",
            "external_partner",
            "cross_domain",
            "other"
          ]
        },
        "observation_status": {
          "type": "string",
          "enum": [
            "observed",
            "asserted",
            "inferred",
            "external"
          ]
        },
        "temporal_context": {
          "$ref": "#/$defs/temporal_context"
        },
        "jurisdiction": {
          "type": "string",
          "pattern": "^[A-Z]{2}(-[A-Z0-9]{1,3})?$"
        },
        "source_record_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          },
          "minItems": 1,
          "maxItems": 100
        },
        "subject_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true,
          "maxItems": 100
        },
        "structural_role_assignment_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true,
          "maxItems": 100
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "state_digest": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        }
      }
    },
    "causal_basis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "basis_type",
        "rationale"
      ],
      "properties": {
        "basis_type": {
          "type": "string",
          "enum": [
            "direct_observation",
            "controlled_evidence",
            "temporal_sequence",
            "mechanistic_reasoning",
            "policy_rule",
            "structural_inference",
            "mixed"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "evidence_refs": {
          "$ref": "#/$defs/reference_list"
        },
        "counterevidence_refs": {
          "$ref": "#/$defs/reference_list"
        },
        "alternative_explanation_refs": {
          "$ref": "#/$defs/reference_list"
        }
      }
    },
    "counterfactual_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assessment_status"
      ],
      "properties": {
        "assessment_status": {
          "type": "string",
          "enum": [
            "not_tested",
            "supports_claim",
            "does_not_support_claim",
            "inconclusive"
          ]
        },
        "method": {
          "type": "string",
          "maxLength": 512
        },
        "result_note": {
          "type": "string",
          "maxLength": 2000
        },
        "evidence_refs": {
          "$ref": "#/$defs/reference_list"
        }
      }
    },
    "causal_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edge_id",
        "source_node_ref",
        "target_node_ref",
        "relation_type",
        "claim_status",
        "causal_strength",
        "confidence",
        "temporal_relation",
        "basis"
      ],
      "properties": {
        "edge_id": {
          "type": "string",
          "minLength": 4,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "source_node_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "target_node_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "relation_type": {
          "type": "string",
          "enum": [
            "initiates",
            "enables",
            "triggers",
            "informs",
            "transforms",
            "routes",
            "constrains",
            "verifies",
            "prevents",
            "influences",
            "follows",
            "correlates_with",
            "other"
          ]
        },
        "claim_status": {
          "type": "string",
          "enum": [
            "proposed",
            "supported",
            "accepted",
            "rejected",
            "disputed",
            "superseded"
          ]
        },
        "causal_strength": {
          "type": "string",
          "enum": [
            "necessary",
            "sufficient",
            "material",
            "partial",
            "weak",
            "unknown"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "temporal_relation": {
          "type": "string",
          "enum": [
            "source_before_target",
            "overlaps",
            "simultaneous",
            "unknown"
          ]
        },
        "conditions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "uniqueItems": true,
          "maxItems": 100
        },
        "basis": {
          "$ref": "#/$defs/causal_basis"
        },
        "counterfactual_assessment": {
          "$ref": "#/$defs/counterfactual_assessment"
        },
        "review_required": {
          "type": "boolean",
          "default": false
        },
        "notes": {
          "type": "string",
          "maxLength": 2500
        }
      }
    },
    "causal_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path_id",
        "path_type",
        "node_sequence",
        "edge_sequence",
        "cross_domain",
        "path_status",
        "summary"
      ],
      "properties": {
        "path_id": {
          "type": "string",
          "minLength": 4,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "path_type": {
          "type": "string",
          "enum": [
            "primary",
            "alternative",
            "verification",
            "disputed"
          ]
        },
        "node_sequence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "minItems": 2,
          "maxItems": 1000
        },
        "edge_sequence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "minItems": 1,
          "maxItems": 999
        },
        "cross_domain": {
          "const": true
        },
        "path_status": {
          "type": "string",
          "enum": [
            "proposed",
            "supported",
            "accepted",
            "rejected",
            "disputed",
            "superseded"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 3000
        },
        "outcome_node_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "continuity_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assessment_id",
        "path_ref",
        "continuity_type",
        "from_node_ref",
        "to_node_ref",
        "continuity_status"
      ],
      "properties": {
        "assessment_id": {
          "type": "string",
          "minLength": 4,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "path_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "continuity_type": {
          "type": "string",
          "enum": [
            "purpose",
            "governance",
            "privacy_transformation",
            "identity_scope",
            "processing_constraint"
          ]
        },
        "from_node_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "to_node_ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "continuity_status": {
          "type": "string",
          "enum": [
            "continuous",
            "conditional",
            "broken",
            "not_applicable",
            "unknown"
          ]
        },
        "evidence_refs": {
          "$ref": "#/$defs/reference_list"
        },
        "break_reason": {
          "type": "string",
          "maxLength": 2000
        },
        "required_action": {
          "type": "string",
          "maxLength": 2000
        },
        "review_required": {
          "type": "boolean",
          "default": false
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "continuity_status": {
                "const": "broken"
              }
            },
            "required": [
              "continuity_status"
            ]
          },
          "then": {
            "required": [
              "break_reason",
              "required_action"
            ]
          }
        }
      ]
    },
    "unresolved_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issue_id",
        "issue_type",
        "description",
        "resolution_status"
      ],
      "properties": {
        "issue_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "issue_type": {
          "type": "string",
          "enum": [
            "missing_event",
            "temporal_conflict",
            "causal_ambiguity",
            "purpose_drift",
            "governance_break",
            "privacy_break",
            "alternative_explanation",
            "insufficient_evidence",
            "other"
          ]
        },
        "related_ref": {
          "type": "string",
          "maxLength": 512
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2500
        },
        "resolution_status": {
          "type": "string",
          "enum": [
            "open",
            "under_review",
            "resolved",
            "accepted_as_unknown"
          ]
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_status"
      ],
      "properties": {
        "review_status": {
          "type": "string",
          "enum": [
            "not_required",
            "pending",
            "approved",
            "rejected",
            "disputed"
          ]
        },
        "reviewer_ref": {
          "type": "string",
          "maxLength": 512
        },
        "reviewed_at": {
          "type": "string",
          "format": "date-time"
        },
        "review_notes": {
          "type": "string",
          "maxLength": 4000
        },
        "audit_refs": {
          "$ref": "#/$defs/reference_list"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "review_status": {
                "enum": [
                  "approved",
                  "rejected",
                  "disputed"
                ]
              }
            },
            "required": [
              "review_status"
            ]
          },
          "then": {
            "required": [
              "reviewer_ref",
              "reviewed_at"
            ]
          }
        }
      ]
    }
  }
}
